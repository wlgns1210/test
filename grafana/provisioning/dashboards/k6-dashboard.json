        {
          "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
          "rawQuery": true,
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time(1m) fill(previous)",
          "refId": "C",
          "alias": "P95"
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
          "rawQuery": true,
          "query": "SELECT percentile(\"value\", 99) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time(1m) fill(previous)",
          "refId": "D",
          "alias": "P99"
        }
      ]
